# ─── SmartStadium Backend — Environment Variables ─────────────────────────────
# Copy to .env and fill in values before starting the server.
# Never commit the real .env file.

# Server
PORT=3001
NODE_ENV=development        # development | production | test

# Security
# Comma-separated list of allowed browser origins for CORS.
# In production set this to your actual frontend domain(s).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin API key — protects POST /api/simulate from unauthorised access.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Leave empty in development to allow unauthenticated access (a warning is logged).
ADMIN_API_KEY=

# Database
# Path to the SQLite database file for persistent order/alert storage.
# Use :memory: for a purely in-memory database (resets on restart).
DB_PATH=./data/stadium.db

# Logging
# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ─── Google Cloud Integration ──────────────────────────────────────────────
# Required for Vertex AI (Gemini 2.5 Flash) operational insights.
# Project ID can be found in your GCP console.
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1

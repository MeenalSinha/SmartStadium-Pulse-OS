{
  "name": "smartstadium-backend",
  "version": "1.2.0",
  "description": "SmartStadium Pulse OS — Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --forceExit --detectOpenHandles --coverage"
  },
  "dependencies": {
    "@google-cloud/error-reporting": "^3.0.5",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/vertexai": "^1.12.0",
    "apicache": "^1.6.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "pino": "^8.21.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.6.1",
    "speed-measure-webpack-plugin": "^1.6.0",
    "sql.js": "^1.12.0",
    "uuid": "^9.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    }
  }
}

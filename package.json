{
  "name": "smartstadium-pulse-os",
  "version": "1.2.0",
  "description": "SmartStadium Pulse OS — Monorepo root",
  "private": true,
  "scripts": {
    "dev":            "concurrently \"npm run dev --prefix backend\" \"npm run start --prefix frontend\"",
    "install:all":    "npm install && npm install --prefix backend && npm install --prefix frontend",
    "test":           "npm test --prefix backend",
    "test:coverage":  "npm run test:coverage --prefix backend",
    "start:backend":  "npm run start --prefix backend",
    "start:frontend": "npm run start --prefix frontend",
    "docker:up":      "docker-compose up -d",
    "docker:down":    "docker-compose down",
    "docker:logs":    "docker-compose logs -f",
    "pm2:start":      "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop":       "pm2 stop smartstadium-backend",
    "pm2:logs":       "pm2 logs smartstadium-backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
